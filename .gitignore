# Зависимости — Amvera сама выполнит npm install во время сборки.
# Если закоммитить node_modules, нативные модули (например, sqlite3),
# собранные под вашу ОС (Windows/macOS), не будут работать в Linux-контейнере Amvera.
node_modules/

# Локальные данные для разработки (на самой Amvera используется /data — постоянное хранилище)
data/
uploads/
db.sqlite

# Переменные окружения / секреты — задаются в Amvera через "Переменные и секреты", а не в коде
.env

# Логи
*.log
npm-debug.log*
